# Production Environment Variables Template
# Copy this file to .env on your production server and fill in the values

# Database - Use production PostgreSQL connection string
DATABASE_URL="postgresql://username:password@host:5432/database_name"

# App URL - Your production domain
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# JWT Secret - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICAL: Must be a strong random secret (64+ characters)
JWT_SECRET="REPLACE_WITH_STRONG_RANDOM_SECRET_64_CHARS_OR_MORE"

# Session Secret - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICAL: Must be a strong random secret (64+ characters)
SESSION_SECRET="REPLACE_WITH_STRONG_RANDOM_SECRET_64_CHARS_OR_MORE"

# SMTP Configuration for Email Notifications
# Used for password reset emails and ticket assignment notifications
SMTP_HOST="smtp.office365.com"
SMTP_PORT="587"
SMTP_USER="your-email@yourdomain.com"
SMTP_PASSWORD="your-email-password"

# Optional: Redis for caching (recommended for production)
# REDIS_URL="redis://localhost:6379"

# Node Environment
NODE_ENV="production"
