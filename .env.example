# Database Connection
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cookie Security Settings
# IMPORTANT: Set to 'false' for HTTP servers (development/staging without SSL)
# Set to 'true' for HTTPS servers (production with SSL certificate)
USE_SECURE_COOKIES="false"

# JWT Secret for fast authentication
# Generate using: node scripts/generate-secrets.js
JWT_SECRET="your-jwt-secret-here"

# Session Secret for session management
# Generate using: node scripts/generate-secrets.js
SESSION_SECRET="your-session-secret-here"

# SMTP Configuration for Email Notifications
SMTP_HOST="smtp.office365.com"
SMTP_PORT="587"
SMTP_USER="your-email@domain.com"
SMTP_PASSWORD="your-app-password"

# Node Environment
NODE_ENV="development"
